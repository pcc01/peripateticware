# ============================================================================
# SPECIAL: Database Files (Both Apps)
# ============================================================================
# Don't commit database dumps unless intentional
# Use: git add database_backup.sql --force (if you need to)

database/backups/*.sql
database/backups/*.dump
*.sql.bak
*.sql.backup

# ============================================================================
# SPECIAL: Credential Files (Highly Important)
# ============================================================================
# These should NEVER be committed - they are in .gitignore for safety

.env*
!.env.example
!.env.example_old
secrets/
.aws/
.credentials

# OAuth2 Secrets
oauth_secrets/
auth_tokens/

# ============================================================================
# DOCUMENTATION: What NOT to commit
# ============================================================================
#
# ❌ DO NOT COMMIT:
# - .env files (environment variables with secrets)
# - node_modules/ (generated by npm install)
# - __pycache__/ (Python bytecode)
# - .venv/ or venv/ (virtual environments)
# - API keys, tokens, passwords
# - Private ssh keys
# - Database backups with real data
# - node_modules/ or pip cache
# - Build outputs (dist/, build/)
# - IDE local settings (.vscode/, .idea/)
# - OS files (.DS_Store, Thumbs.db)
#
# ✅ DO COMMIT:
# - requirements.txt (Python dependencies)
# - package.json (Node dependencies)
# - .env.example (template for env variables)
# - Source code (.py, .tsx, .ts, .js)
# - Configuration files (*.config.ts, *.config.js)
# - Documentation (*.md)
# - License files
# - .gitignore itself
#
# ============================================================================
# HELPFUL COMMANDS
# ============================================================================
#
# See what would be ignored:
#   git check-ignore -v .env
#
# Check if a file is tracked:
#   git ls-files | grep .env
#
# Remove tracked files (after adding to .gitignore):
#   git rm --cached .env
#   git commit -m "remove: stop tracking .env files"
#
# Add untracked files:
#   git add .
#   git add *.py
#
# Check git status:
#   git status
#
# ============================================================================