# Peripateticware Backend Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (add to .gitignore)

# ============================================================================
# APPLICATION SETTINGS
# ============================================================================

# App name (for logging/monitoring)
APP_NAME=Peripateticware

# Environment: development, staging, production
ENVIRONMENT=development

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://peripateticware_user:peripateticware_secure_password_dev@postgres:5432/peripateticware

# For local testing without Docker:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/peripateticware

# ============================================================================
# REDIS CACHE CONFIGURATION
# ============================================================================

# Redis connection URL for caching and session management
REDIS_URL=redis://redis:6379/0

# For local testing:
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# LLM PROVIDER SELECTION
# ============================================================================

# Which LLM provider to use: "ollama" or "claude"
# - ollama: Run models locally (free, privacy-first)
# - claude: Use Anthropic's Claude API (requires API key)
LLM_PROVIDER=ollama

# ============================================================================
# OLLAMA CONFIGURATION (Local LLM Models)
# ============================================================================

# Base URL where Ollama is running
# Docker Compose: http://host.docker.internal:11434
# Local machine: http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Text generation model for Q&A and inference
# Options: llama2, llama3, mistral, neural-chat, etc.
# Recommended for education: llama3 or llama2
OLLAMA_MODEL_TEXT=llama3

# Vision model for image analysis
# Options: llava (recommended)
OLLAMA_MODEL_VISION=llava

# Audio model for transcription (optional)
# Options: whisper
OLLAMA_MODEL_AUDIO=karanchopda333/whisper

# ============================================================================
# CLAUDE API CONFIGURATION (Cloud LLM)
# ============================================================================

# Only needed if LLM_PROVIDER=claude

# Your Anthropic API key
# Get from: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-...your-key-here...

# Claude model to use
# Latest recommended: claude-3-5-sonnet-20241022
# Also available: claude-3-opus, claude-3-sonnet, claude-3-haiku
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Maximum tokens for Claude responses
CLAUDE_MAX_TOKENS=2048

# ============================================================================
# API SERVER CONFIGURATION
# ============================================================================

# Host to bind to (0.0.0.0 = all interfaces, 127.0.0.1 = localhost only)
API_HOST=0.0.0.0

# Port to run API on
API_PORT=8010

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Secret key for JWT token signing
# Generate a strong one: python -c "import secrets; print(secrets.token_urlsafe(32))"
# CHANGE THIS IN PRODUCTION!
SECRET_KEY=dev-secret-key-change-in-production

# JWT algorithm (don't change unless you know what you're doing)
ALGORITHM=HS256

# How long access tokens are valid (in minutes)
# 1440 = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed origins for CORS requests
# Use "*" for development (allow all origins)
# In production, specify exact domains: "https://app.example.com,https://www.example.com"
CORS_ORIGINS=*

# ============================================================================
# VECTOR DATABASE CONFIGURATION
# ============================================================================

# Embedding dimension for vector search
# Standard: 384 (for all-MiniLM-L6-v2 model)
# Don't change this unless you know what you're doing
VECTOR_DIMENSION=384

# ============================================================================
# RAG (RETRIEVAL-AUGMENTED GENERATION) CONFIGURATION
# ============================================================================

# Size of text chunks for RAG retrieval
# Smaller chunks = more specific but requires more queries
# Larger chunks = broader context but less precise
# Recommended: 512
CHUNK_SIZE=512

# Overlap between chunks (for context continuity)
# Recommended: 128 (25% of chunk size)
CHUNK_OVERLAP=128

# Number of top documents to retrieve from curriculum
# Higher = more context but slower
# Lower = faster but less context
# Recommended: 5
TOP_K_RETRIEVAL=5

# ============================================================================
# OBSERVABILITY & MONITORING
# ============================================================================

# Enable Prometheus metrics collection
ENABLE_METRICS=true

# Port for Prometheus metrics endpoint
PROMETHEUS_PORT=8001

# ============================================================================
# EMAIL CONFIGURATION (For notifications, password resets, etc.)
# ============================================================================

# SMTP server for sending emails
SMTP_SERVER=smtp.gmail.com

# SMTP port (25, 465, or 587)
SMTP_PORT=587

# Email account for sending
SMTP_EMAIL=your-email@gmail.com

# SMTP password or app-specific password
SMTP_PASSWORD=your-app-password

# Email address for automated messages to come from
FROM_EMAIL=noreply@peripateticware.com

# ============================================================================
# PRIVACY & COMPLIANCE CONFIGURATION
# ============================================================================

# Enable FERPA (Family Education Rights and Privacy Act) compliance
ENABLE_FERPA=true

# Enable COPPA (Children's Online Privacy Protection) for under-13 users
ENABLE_COPPA=true

# Enable GDPR compliance features
ENABLE_GDPR=true

# Data retention period (in days)
# FERPA recommends 7 years (2555 days)
DATA_RETENTION_DAYS=2555

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable real-time WebSocket features
ENABLE_WEBSOCKET=true

# Enable file uploads (activities with photos, documents)
ENABLE_FILE_UPLOADS=true

# Enable advanced analytics and insights
ENABLE_ANALYTICS=true

# Enable offline sync for mobile app
ENABLE_OFFLINE_SYNC=true

# Enable AI-powered suggestions and analysis
ENABLE_AI_FEATURES=true

# ============================================================================
# EXTERNAL INTEGRATIONS (Optional)
# ============================================================================

# Google Classroom integration
GOOGLE_CLASSROOM_CLIENT_ID=your-google-client-id
GOOGLE_CLASSROOM_CLIENT_SECRET=your-google-client-secret

# Clever SSO integration
CLEVER_CLIENT_ID=your-clever-client-id
CLEVER_CLIENT_SECRET=your-clever-client-secret

# Firebase for push notifications
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# Sentry for error tracking (optional)
SENTRY_DSN=https://...@sentry.io/...

# ============================================================================
# DEVELOPMENT & DEBUG OPTIONS
# ============================================================================

# Enable debug mode (verbose logging, detailed errors)
DEBUG=false

# Enable hot reload for development
RELOAD=true

# ============================================================================
# NOTES FOR DIFFERENT ENVIRONMENTS
# ============================================================================

# DEVELOPMENT (Local Machine)
# - Use: OLLAMA_BASE_URL=http://localhost:11434
# - DATABASE_URL points to local PostgreSQL
# - ENVIRONMENT=development
# - DEBUG=true
# - CORS_ORIGINS=*

# DOCKER COMPOSE (Local with Docker)
# - Use: OLLAMA_BASE_URL=http://host.docker.internal:11434
# - DATABASE_URL points to postgres service
# - ENVIRONMENT=development
# - Use docker-compose.yml for database

# PRODUCTION
# - Change SECRET_KEY to a strong random value
# - Set ENVIRONMENT=production
# - DEBUG=false
# - Use strong passwords for databases
# - CORS_ORIGINS should list specific domains only
# - Use environment-specific secrets management (AWS Secrets, etc.)
# - Enable all security features (FERPA, COPPA, GDPR)
# - Use Claude API or managed Ollama service
# - Set up proper monitoring and alerting

# ============================================================================
# QUICK START COMMANDS
# ============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env

# 2. Edit .env with your values:
#    vim .env

# 3. Start with Docker Compose:
#    docker-compose up -d

# 4. Or start locally (requires PostgreSQL, Redis, Ollama):
#    python main.py

# ============================================================================
# SECURITY REMINDERS
# ============================================================================

# ⚠️ NEVER commit .env to version control
# ⚠️ NEVER share SECRET_KEY or API keys
# ⚠️ Change default passwords in production
# ⚠️ Use HTTPS in production (not HTTP)
# ⚠️ Keep SECRET_KEY secret and rotate periodically
# ⚠️ Use strong database passwords in production
# ⚠️ Enable firewall rules to limit database access
# ⚠️ Monitor logs for suspicious activity

# ============================================================================
# SUPPORT & DOCUMENTATION
# ============================================================================

# For more info, see:
# - Backend Development: docs/DEVELOPMENT.md
# - Architecture: docs/ARCHITECTURE.md
# - Deployment: docs/DEPLOYMENT_GUIDE.md
# - Environment Variables: See core/config.py
