# ============================================================================
# PERIPATETICWARE ENVIRONMENT VARIABLES
# Phase 1-3 (Main App) + Phase 7 (Parent Portal)
# ============================================================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control (add to .gitignore)
# ============================================================================

# ============================================================================
# SECTION 1: PHASE 1-3 BACKEND CONFIGURATION (Existing)
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# Database (Main App)
DATABASE_URL=postgresql+asyncpg://peripateticware_user:peripateticware_secure_password_dev@postgres:5432/peripateticware

# Redis (Cache)
REDIS_URL=redis://redis:6379/0

# CORS Configuration
CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000", "http://localhost:19000", "http://localhost:19006", "http://localhost:5174", "*"]
ALLOWED_HOSTS=["*"]

# Security
SECRET_KEY=dev-secret-key-change-in-production

# LLM Configuration (Phase 5)
LLM_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-your-api-key-here
CLAUDE_MODEL=claude-3-5-sonnet-20241022
CLAUDE_MAX_TOKENS=2048

# Ollama Configuration (Local LLM Alternative)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_TEXT=llama2
OLLAMA_MODEL_VISION=llava
OLLAMA_MODEL_AUDIO=whisper

# ============================================================================
# SECTION 2: PHASE 1-3 FRONTEND CONFIGURATION (Existing)
# ============================================================================

# Frontend API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Frontend Environment
VITE_ENV=development
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ASR=true
VITE_ENABLE_PORTFOLIO_EXPORT=true

# Frontend Analytics (Optional)
VITE_ANALYTICS_ENABLED=false
VITE_GOOGLE_ANALYTICS_ID=

# ============================================================================
# SECTION 3: PHASE 7 PARENT PORTAL - BACKEND (NEW)
# ============================================================================
# These variables are used by the parent portal backend service (fastapi-parent)
# They are similar to Phase 1-3 but with separate configuration for parent portal

# Phase 7 API Server
PARENT_API_HOST=0.0.0.0
PARENT_API_PORT=8000  # Port inside container (mapped to 8001 externally)

# Phase 7 Database (Separate from main app)
DATABASE_URL_PARENT=postgresql+asyncpg://parent_portal_user:parent_portal_secure_password_dev@postgres-parent:5432/peripateticware_parent_portal
DB_PASSWORD_PARENT=parent_portal_secure_password_dev

# Phase 7 Redis (Separate cache instance)
REDIS_URL_PARENT=redis://redis-parent:6379

# Phase 7 Read-Only Access to Main Database (for fetching student data)
MAIN_DB_URL=postgresql+asyncpg://peripateticware_user:peripateticware_secure_password_dev@postgres:5432/peripateticware
MAIN_DB_READER_URL=postgresql+asyncpg://peripateticware_user:peripateticware_secure_password_dev@postgres:5432/peripateticware

# Phase 7 Authentication
JWT_SECRET_KEY=dev-secret-key-parent-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Phase 7 OAuth2 Configuration (GitHub Login)
GITHUB_CLIENT_ID=your-github-app-client-id
GITHUB_CLIENT_SECRET=your-github-app-client-secret

# Phase 7 OAuth2 Configuration (Google Login)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Phase 7 Security
SECRET_KEY_PARENT=dev-secret-key-parent-change-in-production

# Phase 7 LLM Integration (Anthropic)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Phase 7 Environment
ENVIRONMENT_PARENT=development
DEBUG_PARENT=True
LOG_LEVEL_PARENT=INFO

# ============================================================================
# SECTION 4: PHASE 7 PARENT PORTAL - FRONTEND (NEW)
# ============================================================================
# These variables are used by the parent portal React frontend

# Phase 7 Frontend API Configuration
VITE_API_URL_PARENT=http://localhost:8001
VITE_MAIN_APP_URL=http://localhost:5173  # Link to main app from parent portal
VITE_API_TIMEOUT_PARENT=30000

# Phase 7 Frontend Environment
VITE_ENV_PARENT=development
VITE_LOG_LEVEL_PARENT=debug

# Phase 7 Feature Flags
VITE_ENABLE_MESSAGING_PARENT=true
VITE_ENABLE_ANALYTICS_PARENT=false
VITE_ENABLE_EXPORT_PARENT=true
VITE_ENABLE_NOTIFICATIONS_PARENT=true

# ============================================================================
# SECTION 5: EMAIL CONFIGURATION (Phase 2 - Both Apps)
# ============================================================================

# Email Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Email Settings
EMAIL_FROM_NAME=Peripateticware
EMAIL_FROM_ADDRESS=noreply@peripateticware.com
EMAIL_REPLY_TO=support@peripateticware.com

# Phase 7 Email Configuration
PARENT_PORTAL_EMAIL_FROM=parent-support@peripateticware.com
PARENT_PORTAL_SMTP_HOST=smtp.gmail.com
PARENT_PORTAL_SMTP_PORT=587
PARENT_PORTAL_SMTP_USER=your-email@gmail.com
PARENT_PORTAL_SMTP_PASSWORD=your-app-specific-password

# ============================================================================
# SECTION 6: OPTIONAL INTEGRATIONS
# ============================================================================

# Firebase (Optional - for push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id
FIREBASE_APP_ID=your-firebase-app-id

# Sentry (Optional - Error tracking)
SENTRY_DSN=https://...@sentry.io/...
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=1.0.0

# Google Maps (Optional - for location features)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ============================================================================
# SECTION 7: DEVELOPMENT OPTIONS
# ============================================================================

# Enable debug endpoints
ENABLE_DEBUG_ENDPOINTS=true

# Enable test data generation
ENABLE_TEST_DATA=false

# Cache strategy
CACHE_STRATEGY=redis

# ============================================================================
# QUICK START GUIDE
# ============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env with your values:
#    nano .env  (or your favorite editor)
#
# 3. For local development with Docker:
#    docker-compose up -d
#
# 4. Access the applications:
#    Main app:     http://localhost:5173 (frontend)
#    Main app API: http://localhost:8000 (backend)
#    Parent portal: http://localhost:5174 (frontend)
#    Parent portal API: http://localhost:8001 (backend)
#
# ============================================================================
# ENVIRONMENT EXAMPLES
# ============================================================================
#
# DEVELOPMENT (Local):
# ENVIRONMENT=development
# DEBUG=True
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/peripateticware
# VITE_API_URL=http://localhost:8000
# CORS_ORIGINS=["http://localhost:5173", "http://localhost:5174", "*"]
#
# STAGING (Beta):
# ENVIRONMENT=staging
# DEBUG=False
# DATABASE_URL=postgresql+asyncpg://user:pass@staging-db:5432/peripateticware
# VITE_API_URL=https://staging-api.peripateticware.com
#
# PRODUCTION:
# ENVIRONMENT=production
# DEBUG=False
# DATABASE_URL=postgresql+asyncpg://user:pass@prod-db:5432/peripateticware
# VITE_API_URL=https://api.peripateticware.com
#
# ============================================================================
# IMPORTANT NOTES
# ============================================================================
#
# ⚠️ Never commit .env to version control - it's in .gitignore
# ⚠️ Never use development secrets in production
# ⚠️ All CLAUDE_API_KEY, JWT_SECRET_KEY are sensitive - keep secure
# ⚠️ Database passwords should be strong in production
# ⚠️ OAuth2 secrets (GitHub, Google) are sensitive - keep secure
# ⚠️ For production, use environment variables from your deployment platform
#
# ============================================================================
# OPTIONAL: Create separate .env files for different environments
# ============================================================================
#
# .env.development (local development):
#   Copy all variables from this file, use localhost URLs
#
# .env.production (production):
#   Use production URLs and secrets
#   Load from secrets management system (AWS Secrets, Azure Key Vault, etc.)
#
# To use environment-specific .env files:
#   docker-compose --env-file .env.production up -d
#
# ============================================================================