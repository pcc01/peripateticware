# ==============================================================================
# backend/.env.example - UPDATED FOR OLLAMA-FIRST
# ==============================================================================

# Database
DATABASE_URL=postgresql://peripateticware:secure_password@postgres:5432/peripateticware
DB_USER=peripateticware
DB_PASSWORD=secure_password
DB_NAME=peripateticware
DB_HOST=postgres
DB_PORT=5432

# Redis (for async tasks)
REDIS_URL=redis://redis:6379

# API Configuration
API_TITLE=Peripateticware API
API_VERSION=6.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# File Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,webm,wav,mp3,m4a,pdf

# ==============================================================================
# ASR CONFIGURATION (Speech-to-Text)
# ==============================================================================
# 
# APPROACH: Local-First with Cloud Fallback
# 
# Primary: Ollama (LOCAL, FREE, PRIVATE)
#   - Install Ollama: https://ollama.ai
#   - Pull model: ollama pull mistral
#   - Enable: OLLAMA_ENABLED=true
#   - Will fall back to cloud providers if local fails
#
# Secondary: OpenAI Whisper API (CLOUD, OPTIONAL FALLBACK)
#   - Get key: https://platform.openai.com/api-keys
#   - Cost: $0.006 per 15 seconds (~$1.44/hour)
#   - Only used if Ollama is unavailable
#
# Tertiary: Anthropic Claude (CLOUD, ULTIMATE FALLBACK)
#   - Get key: https://console.anthropic.com
#   - Cost: ~$1/hour per million tokens
#   - Only used if both Ollama and OpenAI fail
#

# LOCAL OLLAMA (PRIMARY - RECOMMENDED FOR DEVELOPMENT)
OLLAMA_ENABLED=true
OLLAMA_HOST=http://ollama:11434  # In Docker, use service name; locally use http://localhost:11434
OLLAMA_MODEL=mistral              # Options: mistral, neural-chat, llama2, orca-mini

# CLOUD FALLBACK: OpenAI Whisper API
OPENAI_API_KEY=sk-your-openai-api-key-here
# Leave blank to skip OpenAI fallback

# CLOUD FALLBACK: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# Leave blank to skip Claude fallback

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@peripateticware.edu

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://peripateticware.edu

# SSL/TLS (for production)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_ASR_TRANSCRIPTION=true
ENABLE_OFFLINE_SYNC=true
ENABLE_PORTFOLIO_EXPORT=true


# ==============================================================================
# frontend/.env.example - UNCHANGED
# ==============================================================================

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Environment
VITE_ENV=development
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ASR=true
VITE_ENABLE_PORTFOLIO_EXPORT=true

# Third-party APIs (if needed)
VITE_OPENAI_API_KEY=
VITE_MAPBOX_TOKEN=

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_GOOGLE_ANALYTICS_ID=


# ==============================================================================
# backend/.env.example
# Environment variables for Phase 6 backend
# ==============================================================================

# Database
DATABASE_URL=postgresql://peripateticware:secure_password@postgres:5432/peripateticware
DB_USER=peripateticware
DB_PASSWORD=secure_password
DB_NAME=peripateticware
DB_HOST=postgres
DB_PORT=5432

# Redis (for async tasks)
REDIS_URL=redis://redis:6379

# API Configuration
API_TITLE=Peripateticware API
API_VERSION=6.0.0
ENVIRONMENT=development
LOG_LEVEL=INFO
BACKEND_PORT=8000

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400

# File Storage
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=500
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4,webm,wav,mp3,m4a,pdf

# ASR Configuration (Speech-to-Text)
# Primary: Local Whisper (Docker)
WHISPER_LOCAL_URL=http://whisper:9000
WHISPER_LOCAL_ENABLED=true

# Secondary: OpenAI Whisper API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_WHISPER_ENABLED=true

# Fallback: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_ENABLED=true

# Optional: Ollama (local inference)
OLLAMA_HOST=http://ollama:11434
OLLAMA_ENABLED=false
OLLAMA_MODEL=llama3

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@peripateticware.edu

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://peripateticware.edu

# SSL/TLS (for production)
SSL_ENABLED=false
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
SENTRY_DSN=
DATADOG_API_KEY=

# Feature Flags
ENABLE_ASR_TRANSCRIPTION=true
ENABLE_OFFLINE_SYNC=true
ENABLE_PORTFOLIO_EXPORT=true