    "access_mechanism": {
      "required": true,
      "response_days": 30,
      "severity": "error",\n      \"description\": \"Must provide reasonable access to personal data held\"\n    },\n    \"correction_mechanism\": {\n      \"required\": true,\n      \"severity\": \"error\",\n      \"description\": \"Must provide mechanism to correct inaccurate data\"\n    }\n  },\n  \n  \"data_retention\": {\n    \"personal_data\": {\n      \"retention_months\": 12,\n      \"deletion_method\": \"delete_or_anonymize\",\n      \"archival_allowed\": false\n    },\n    \"learning_activity_data\": {\n      \"retention_months\": 24,\n      \"deletion_method\": \"delete_or_anonymize\",\n      \"archival_allowed\": false\n    }\n  },\n  \n  \"third_party_restrictions\": {\n    \"forbidden\": [],\n    \"requires_explicit_consent\": [\n      \"third_party_sharing\",\n      \"cross_border_transfer\"\n    ],\n    \"allowed_without_consent\": [\n      \"school_staff\",\n      \"authorized_agents\"\n    ]\n  },\n  \n  \"warnings\": [\n    \"PDPA applies to organizations in Singapore processing personal data\",\n    \"Parental consent required for children under 13\",\n    \"Must notify individuals before collecting personal data\",\n    \"Must protect data against loss and unauthorized access\",\n    \"Must not retain data longer than necessary\",\n    \"Must respond to access/correction requests\",\n    \"Penalties can include fines up to SGD 1 million and/or imprisonment\"\n  ],\n  \n  \"requirements\": [\n    \"Obtain explicit parental consent for children under 13\",\n    \"Notify individuals of data collection and purposes\",\n    \"Implement security measures to protect personal data\",\n    \"Do not retain personal data longer than necessary\",\n    \"Ensure accuracy of personal data\",\n    \"Provide access to personal data held\",\n    \"Allow correction of inaccurate personal data\",\n    \"Handle complaints and provide remedies\"\n  ]\n}\nEOF
