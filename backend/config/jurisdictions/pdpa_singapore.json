  "legal_obligations": [
    "Consent for collection and use of personal data",
    "Notification of collection and purposes",
    "Accuracy and Protection of personal data",
    "Protection of personal data against loss and unauthorized access",
    "Retention of personal data - do not retain longer than necessary",
    "Openness - make available details of personal data held",
    "Accuracy - take reasonable steps to ensure accuracy",
    "Access - reasonable access to personal data",
    "Correction - reasonable efforts to correct inaccurate data",
    "Complaint handling and remedies"
