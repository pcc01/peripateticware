{
  "name": "peripateticware-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "build:preview": "eas build --platform all --build-type preview",
    "build:production": "eas build --platform all --build-type production",
    "build:ios": "eas build --platform ios --build-type production",
    "build:android": "eas build --platform android --build-type production"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.72.0",
    "expo": "^49.0.0",
    "expo-router": "^2.0.0",
    "expo-location": "^16.1.0",
    "expo-notifications": "^0.18.0",
    "expo-secure-store": "^12.3.0",
    "expo-status-bar": "^1.6.0",
    "@react-navigation/native": "^6.1.7",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native-stack": "^6.9.13",
    "@react-native-async-storage/async-storage": "^1.19.0",
    "@react-native-community/netinfo": "^11.0.0",
    "zustand": "^4.4.0",
    "axios": "^1.6.0",
    "formik": "^2.4.5",
    "yup": "^1.3.3",
    "react-native-gesture-handler": "^2.13.4",
    "react-native-reanimated": "^3.5.0",
    "react-native-safe-area-context": "^4.7.2",
    "react-native-screens": "^3.26.0",
    "react-native-vector-icons": "^10.0.0",
    "date-fns": "^2.30.0",
    "lodash.debounce": "^4.0.8"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.72.0",
    "@types/jest": "^29.5.0",
    "@types/lodash.debounce": "^4.0.7",
    "typescript": "^5.1.0",
    "jest": "^29.6.0",
    "jest-expo": "^49.0.0",
    "ts-jest": "^29.1.0",
    "@testing-library/react-native": "^12.4.0",
    "@testing-library/jest-native": "^5.4.0",
    "jest-mock-axios": "^4.6.0",
    "eslint": "^8.48.0",
    "eslint-config-react-app": "^7.0.1",
    "@babel/preset-env": "^7.22.0",
    "@babel/preset-typescript": "^7.22.0"
  }
