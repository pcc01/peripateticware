{
  "expo": {
    "name": "Peripateticware",
    "slug": "peripateticware",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    
    "ios": {
     
      "bundleIdentifier": "com.peripateticware.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.peripateticware.app"
    },
  
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Peripateticware to access your location."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "peripateticware-mobile"
      }
    }
  }
}
