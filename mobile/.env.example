# Peripateticware Mobile App Environment Variables

# API Configuration
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_ENV=development

# App Configuration
EXPO_PUBLIC_APP_NAME=Peripateticware
EXPO_PUBLIC_APP_VERSION=1.0.0

# Feature Flags
EXPO_PUBLIC_ENABLE_ANALYTICS=false
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false
EXPO_PUBLIC_ENABLE_DARK_MODE=true
EXPO_PUBLIC_ENABLE_OFFLINE_SYNC=true

# Firebase Configuration (for Phase 4.7 - Push Notifications)
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
# EXPO_PUBLIC_FIREBASE_API_KEY=your-api-key
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id

# Sentry Configuration (for Phase 4.10 - Crash Reporting)
# EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Analytics Configuration (Phase 4.10)
# EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id

# Timeout Configuration
EXPO_PUBLIC_API_TIMEOUT=10000

# Development Tools
EXPO_PUBLIC_ENABLE_DEBUG_LOGS=true

# Notes:
# - In development, use http://localhost:8000
# - In production, use https://api.peripateticware.com (or your production URL)
# - Keep .env file secure and don't commit to version control
# - Use .env.local for local overrides (add to .gitignore)
# - All EXPO_PUBLIC_ variables are accessible on client side
# - Use only for non-sensitive configuration
