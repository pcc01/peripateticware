# Peripateticware Mobile App Configuration
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control (add to .gitignore)

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL - where your backend is running
# Development (local): http://localhost:8010
# Development (Docker): http://192.168.x.x:8010 (your machine's IP)
# Development (Tailscale): http://100.x.x.x:8010 (your Tailscale IP)
# Production: https://api.peripateticware.com
EXPO_PUBLIC_API_URL=http://localhost:8010

# API timeout in milliseconds (10 seconds recommended)
EXPO_PUBLIC_API_TIMEOUT=10000

# ============================================================================
# ENVIRONMENT & VERSION
# ============================================================================

# Environment: development, staging, production
EXPO_PUBLIC_ENV=development

# App name (displayed in app)
EXPO_PUBLIC_APP_NAME=Peripateticware

# App version (follows semantic versioning)
EXPO_PUBLIC_APP_VERSION=1.0.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable analytics tracking (user behavior, event tracking)
EXPO_PUBLIC_ENABLE_ANALYTICS=false

# Enable crash reporting (Sentry or similar)
EXPO_PUBLIC_ENABLE_CRASH_REPORTING=false

# Enable dark mode toggle in app
EXPO_PUBLIC_ENABLE_DARK_MODE=true

# Enable offline data sync
EXPO_PUBLIC_ENABLE_OFFLINE_SYNC=true

# Enable debug logging (verbose console output)
EXPO_PUBLIC_ENABLE_DEBUG_LOGS=true

# ============================================================================
# FIREBASE CONFIGURATION (Push Notifications)
# ============================================================================

# Optional: Only needed if using Firebase for push notifications

# Firebase project ID
# Get from: https://console.firebase.google.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API key
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key

# Firebase messaging sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id

# Firebase app ID
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id

# ============================================================================
# SENTRY ERROR TRACKING (Crash Reporting)
# ============================================================================

# Optional: Only needed if using Sentry for error tracking

# Sentry DSN (Data Source Name)
# Get from: https://sentry.io
EXPO_PUBLIC_SENTRY_DSN=https://...@sentry.io/...

# ============================================================================
# ANALYTICS CONFIGURATION
# ============================================================================

# Optional: For tracking user behavior and engagement

# Analytics service (e.g., Firebase, Mixpanel, Amplitude)
# Format: firebase, mixpanel, amplitude, custom
EXPO_PUBLIC_ANALYTICS_PROVIDER=firebase

# Analytics tracking ID
EXPO_PUBLIC_ANALYTICS_ID=your-analytics-id

# ============================================================================
# MAP CONFIGURATION
# ============================================================================

# Google Maps API key (for location features)
# Get from: https://console.cloud.google.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Map region center (lat, lng)
EXPO_PUBLIC_MAP_CENTER_LAT=40.7128
EXPO_PUBLIC_MAP_CENTER_LNG=-74.0060

# Default zoom level
EXPO_PUBLIC_MAP_DEFAULT_ZOOM=12

# ============================================================================
# CAMERA & LOCATION PERMISSIONS
# ============================================================================

# iOS camera usage description
EXPO_PUBLIC_CAMERA_PERMISSION_MESSAGE=We need camera access to capture evidence for activities

# iOS location usage description
EXPO_PUBLIC_LOCATION_PERMISSION_MESSAGE=We need your location to show where activities take place

# Allow background location tracking (iOS)
EXPO_PUBLIC_ALLOW_BACKGROUND_LOCATION=true

# ============================================================================
# LOCALIZATION & LANGUAGE
# ============================================================================

# Default language code (ISO 639-1)
# Options: en, es, fr, de, pt, it, nl, pl, etc.
EXPO_PUBLIC_DEFAULT_LANGUAGE=en

# Enable language switching in app
EXPO_PUBLIC_ENABLE_LANGUAGE_SWITCHING=true

# List of supported languages (comma-separated)
EXPO_PUBLIC_SUPPORTED_LANGUAGES=en,es,fr,de,pt

# ============================================================================
# THEME & APPEARANCE
# ============================================================================

# Primary app color (hex code)
EXPO_PUBLIC_PRIMARY_COLOR=#0066cc

# Secondary app color (hex code)
EXPO_PUBLIC_SECONDARY_COLOR=#1D9E75

# App logo URL (for splash screen)
EXPO_PUBLIC_LOGO_URL=https://example.com/logo.png

# ============================================================================
# DEVELOPMENT & DEBUG
# ============================================================================

# Enable development menu (shake device to open menu)
EXPO_PUBLIC_ENABLE_DEV_MENU=true

# Enable Redux DevTools (if using Redux)
EXPO_PUBLIC_ENABLE_REDUX_DEVTOOLS=true

# Log all API requests/responses
EXPO_PUBLIC_LOG_API_CALLS=true

# ============================================================================
# TESTING & STAGING
# ============================================================================

# Test user credentials (for development only!)
# Remove in production
EXPO_PUBLIC_TEST_EMAIL=test@example.com
EXPO_PUBLIC_TEST_PASSWORD=testpassword123

# Enable test mode (uses mock data instead of real API)
EXPO_PUBLIC_TEST_MODE=false

# ============================================================================
# OFFLINE CONFIGURATION
# ============================================================================

# Enable offline-first mode (works without internet)
EXPO_PUBLIC_OFFLINE_MODE_ENABLED=true

# Sync interval when online (in seconds)
# How often to sync offline changes with server
EXPO_PUBLIC_SYNC_INTERVAL=30

# Storage size for offline data (in MB)
EXPO_PUBLIC_OFFLINE_STORAGE_SIZE=100

# ============================================================================
# SECURITY & PRIVACY
# ============================================================================

# Enable SSL pinning (certificate pinning for security)
EXPO_PUBLIC_ENABLE_SSL_PINNING=false

# Enable biometric authentication (fingerprint/face)
EXPO_PUBLIC_ENABLE_BIOMETRIC=true

# Data encryption (encrypt sensitive data locally)
EXPO_PUBLIC_ENABLE_ENCRYPTION=true

# ============================================================================
# PUSH NOTIFICATION CONFIGURATION
# ============================================================================

# Push notification service
# Options: firebase, expo, custom
EXPO_PUBLIC_PUSH_NOTIFICATION_SERVICE=firebase

# Notification sound (iOS)
EXPO_PUBLIC_NOTIFICATION_SOUND=default

# Notification vibration (Android)
EXPO_PUBLIC_NOTIFICATION_VIBRATION=true

# ============================================================================
# ANDROID SPECIFIC CONFIGURATION
# ============================================================================

# Android package name (reverse domain style)
EXPO_PUBLIC_ANDROID_PACKAGE=com.peripateticware.mobile

# Android app signing key (for production releases)
EXPO_PUBLIC_ANDROID_KEY_ALIAS=peripateticware

# ============================================================================
# iOS SPECIFIC CONFIGURATION
# ============================================================================

# iOS bundle ID
EXPO_PUBLIC_IOS_BUNDLE_ID=com.peripateticware.mobile

# iOS team ID (for push notifications)
EXPO_PUBLIC_IOS_TEAM_ID=XXXXXXXXXX

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================

# Max image size for uploads (in MB)
EXPO_PUBLIC_MAX_IMAGE_SIZE=10

# Image compression quality (0-1)
EXPO_PUBLIC_IMAGE_QUALITY=0.8

# Cache duration for API responses (in seconds)
EXPO_PUBLIC_CACHE_DURATION=3600

# ============================================================================
# QUICK START GUIDE
# ============================================================================

# 1. Copy this file to .env.local:
#    cp .env.example .env.local

# 2. Edit .env.local with your values:
#    nano .env.local

# 3. For local development (Tailscale):
#    a) Get your Tailscale IP: tailscale ip -4
#    b) Set EXPO_PUBLIC_API_URL=http://YOUR_TAILSCALE_IP:8010
#    c) Run app on mobile device

# 4. Start app:
#    npm start

# 5. Choose platform:
#    - Press 'i' for iOS simulator
#    - Press 'a' for Android emulator
#    - Scan QR code with Expo Go app (mobile device)

# ============================================================================
# ENVIRONMENT SPECIFIC EXAMPLES
# ============================================================================

# DEVELOPMENT (Local Machine)
# EXPO_PUBLIC_API_URL=http://localhost:8010
# EXPO_PUBLIC_ENV=development
# EXPO_PUBLIC_ENABLE_DEBUG_LOGS=true
# EXPO_PUBLIC_TEST_MODE=false
# EXPO_PUBLIC_OFFLINE_MODE_ENABLED=true

# DEVELOPMENT (Tailscale - Mobile Device)
# EXPO_PUBLIC_API_URL=http://100.x.x.x:8010
# EXPO_PUBLIC_ENV=development
# EXPO_PUBLIC_ENABLE_DEBUG_LOGS=true
# EXPO_PUBLIC_TEST_MODE=false

# STAGING (Beta Testing)
# EXPO_PUBLIC_API_URL=https://staging-api.peripateticware.com
# EXPO_PUBLIC_ENV=staging
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
# EXPO_PUBLIC_ENABLE_DEBUG_LOGS=false

# PRODUCTION (Live Release)
# EXPO_PUBLIC_API_URL=https://api.peripateticware.com
# EXPO_PUBLIC_ENV=production
# EXPO_PUBLIC_ENABLE_ANALYTICS=true
# EXPO_PUBLIC_ENABLE_CRASH_REPORTING=true
# EXPO_PUBLIC_ENABLE_DEBUG_LOGS=false
# EXPO_PUBLIC_TEST_MODE=false

# ============================================================================
# IMPORTANT NOTES
# ============================================================================

# ⚠️ ALL EXPO_PUBLIC_ variables are exposed to the client
# ⚠️ Never put secrets (API keys, passwords) in EXPO_PUBLIC_ variables
# ⚠️ Use environment-specific files for sensitive config
# ⚠️ Don't commit .env.local to version control
# ⚠️ .env.local should be in .gitignore
# ⚠️ For testing, remove test credentials before production
# ⚠️ Update API_URL for different environments
# ⚠️ Firebase/Sentry keys are safe to expose (restricted by domain)

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# If app can't connect to API:
# 1. Check API_URL is correct
# 2. Verify backend is running: curl http://API_URL/health
# 3. Check firewall isn't blocking connection
# 4. On mobile with Tailscale, ensure device is connected
# 5. Check backend CORS settings allow your app origin

# If push notifications don't work:
# 1. Check Firebase config is correct
# 2. Verify notifications are enabled on device
# 3. Check app has notification permissions
# 4. Review Firebase console for errors

# If offline sync fails:
# 1. Enable debug logs to see sync errors
# 2. Check available device storage
# 3. Verify backend is online before syncing
# 4. Clear app cache if sync is stuck

# ============================================================================
# USEFUL COMMANDS
# ============================================================================

# Start development server:
# npm start

# Run on iOS simulator:
# npm run ios

# Run on Android emulator:
# npm run android

# Build for production (iOS):
# eas build --platform ios

# Build for production (Android):
# eas build --platform android

# Submit to App Store:
# eas submit --platform ios

# Submit to Google Play:
# eas submit --platform android

