# Peripateticware Frontend - Environment Configuration

# === API Configuration ===
# Backend API URL - change this to your deployment
VITE_API_URL=http://localhost:8010/api/v1

# === Feature Flags ===
VITE_ENABLE_PRIVACY_ENGINE=true
VITE_ENABLE_AI_ARTIFACT_RETENTION=true
VITE_ENABLE_BATCH_IMPORT=true
VITE_ENABLE_REAL_TIME_MONITORING=true

# === Geolocation Configuration ===
# Google Maps API Key (optional, for advanced features)
VITE_GOOGLE_MAPS_API_KEY=

# === WebSocket Configuration ===
# WebSocket URL for real-time updates (auto-detected from API_URL if not set)
VITE_WEBSOCKET_URL=ws://localhost:8010/api/v1

# === Authentication ===
# Token storage location: 'localStorage' (default) or 'sessionStorage'
VITE_AUTH_STORAGE=localStorage

# === Internationalization ===
# Default language: en, es, ar, ja
VITE_DEFAULT_LANGUAGE=en

# === Map Configuration ===
# Default map center (latitude,longitude)
VITE_MAP_CENTER=40.7128,-74.0060
# Default zoom level
VITE_MAP_ZOOM=13

# === Logging ===
# Log level: debug, info, warn, error
VITE_LOG_LEVEL=info

# === Build Configuration ===
# Public URL path (for subdomain deployments)
VITE_PUBLIC_PATH=/

# === Cloudflare Deployment ===
# Set these for Cloudflare Pages deployment
VITE_DEPLOYMENT_ENV=development

# Possible values: development, staging, production
NODE_ENV=development
