# Peripateticware Frontend (Web) Configuration
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control (add to .gitignore)

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL - where your backend is running
# Development (local): http://localhost:8010
# Development (Docker): http://192.168.x.x:8010 (your machine's IP)
# Production: https://api.peripateticware.com
REACT_APP_API_URL=http://localhost:8010

# API timeout in milliseconds
REACT_APP_API_TIMEOUT=10000

# ============================================================================
# ENVIRONMENT & VERSION
# ============================================================================

# Environment: development, staging, production
REACT_APP_ENV=development

# App name
REACT_APP_APP_NAME=Peripateticware

# App version
REACT_APP_APP_VERSION=1.0.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable analytics tracking
REACT_APP_ENABLE_ANALYTICS=false

# Enable error tracking (Sentry)
REACT_APP_ENABLE_ERROR_TRACKING=false

# Enable dark mode toggle
REACT_APP_ENABLE_DARK_MODE=true

# Enable offline PWA support
REACT_APP_ENABLE_PWA=true

# Enable debug mode
REACT_APP_DEBUG=true

# ============================================================================
# FIREBASE CONFIGURATION (Optional - for push notifications)
# ============================================================================

# Firebase project ID
REACT_APP_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase API key
REACT_APP_FIREBASE_API_KEY=your-firebase-api-key

# Firebase messaging sender ID
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-firebase-sender-id

# Firebase app ID
REACT_APP_FIREBASE_APP_ID=your-firebase-app-id

# ============================================================================
# SENTRY CONFIGURATION (Optional - for error tracking)
# ============================================================================

# Sentry DSN (Data Source Name)
REACT_APP_SENTRY_DSN=https://...@sentry.io/...

# Environment for Sentry
REACT_APP_SENTRY_ENVIRONMENT=development

# Release version for Sentry
REACT_APP_SENTRY_RELEASE=1.0.0

# ============================================================================
# GOOGLE MAPS CONFIGURATION
# ============================================================================

# Google Maps API key (for map features)
REACT_APP_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Default map center (latitude)
REACT_APP_MAP_CENTER_LAT=40.7128

# Default map center (longitude)
REACT_APP_MAP_CENTER_LNG=-74.0060

# Default zoom level
REACT_APP_MAP_DEFAULT_ZOOM=12

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Token storage key
REACT_APP_TOKEN_KEY=peripateticware_token

# Token refresh interval (in seconds)
REACT_APP_TOKEN_REFRESH_INTERVAL=900

# Session timeout (in minutes) - 0 = never timeout
REACT_APP_SESSION_TIMEOUT=0

# ============================================================================
# INTERNATIONALIZATION (i18n)
# ============================================================================

# Default language
REACT_APP_DEFAULT_LANGUAGE=en

# Enable language switching
REACT_APP_ENABLE_LANGUAGE_SWITCHING=true

# Supported languages (comma-separated)
REACT_APP_SUPPORTED_LANGUAGES=en,es,fr,de,pt,it

# ============================================================================
# THEME & STYLING
# ============================================================================

# Primary color (hex)
REACT_APP_PRIMARY_COLOR=#0066cc

# Secondary color (hex)
REACT_APP_SECONDARY_COLOR=#1D9E75

# Success color (hex)
REACT_APP_SUCCESS_COLOR=#4CAF50

# Warning color (hex)
REACT_APP_WARNING_COLOR=#FF9800

# Error color (hex)
REACT_APP_ERROR_COLOR=#F44336

# App logo URL
REACT_APP_LOGO_URL=https://example.com/logo.png

# App favicon URL
REACT_APP_FAVICON_URL=https://example.com/favicon.ico

# ============================================================================
# ANALYTICS CONFIGURATION
# ============================================================================

# Analytics service (firebase, google, custom)
REACT_APP_ANALYTICS_PROVIDER=firebase

# Analytics tracking ID
REACT_APP_ANALYTICS_ID=your-analytics-id

# Google Analytics 4 ID (if using GA4)
REACT_APP_GA4_ID=G-XXXXXXXXXX

# ============================================================================
# DEVELOPER OPTIONS
# ============================================================================

# Enable React DevTools
REACT_APP_ENABLE_DEVTOOLS=true

# Enable Redux DevTools (if using Redux)
REACT_APP_ENABLE_REDUX_DEVTOOLS=true

# Enable query string debugging
REACT_APP_ENABLE_QUERY_DEBUG=true

# Log all API calls
REACT_APP_LOG_API_CALLS=true

# Log all state changes (if using Redux)
REACT_APP_LOG_STATE_CHANGES=true

# ============================================================================
# PERFORMANCE OPTIMIZATION
# ============================================================================

# Enable code splitting
REACT_APP_ENABLE_CODE_SPLITTING=true

# Enable service worker (for PWA offline support)
REACT_APP_ENABLE_SERVICE_WORKER=true

# Cache API responses (in seconds)
REACT_APP_API_CACHE_DURATION=3600

# Max image upload size (in MB)
REACT_APP_MAX_IMAGE_SIZE=10

# Image compression quality (0-1)
REACT_APP_IMAGE_QUALITY=0.8

# ============================================================================
# SECURITY
# ============================================================================

# Enable HTTPS only (production)
REACT_APP_HTTPS_ONLY=false

# Content Security Policy enabled
REACT_APP_ENABLE_CSP=true

# Enable rate limiting on client side
REACT_APP_ENABLE_RATE_LIMITING=true

# ============================================================================
# ACCESSIBILITY
# ============================================================================

# Enable accessibility features
REACT_APP_ENABLE_ACCESSIBILITY=true

# High contrast mode by default
REACT_APP_HIGH_CONTRAST_DEFAULT=false

# Large text by default
REACT_APP_LARGE_TEXT_DEFAULT=false

# ============================================================================
# FEATURE CONTENT
# ============================================================================

# Show beta features
REACT_APP_SHOW_BETA_FEATURES=false

# Show experimental features
REACT_APP_SHOW_EXPERIMENTAL_FEATURES=false

# Show developer menu
REACT_APP_SHOW_DEVELOPER_MENU=true

# ============================================================================
# QUICK START GUIDE
# ============================================================================

# 1. Copy this file to .env.local:
#    cp .env.example .env.local

# 2. Edit .env.local with your values:
#    nano .env.local

# 3. Install dependencies:
#    npm install

# 4. Start development server:
#    npm start

# 5. Open browser:
#    http://localhost:3000

# ============================================================================
# ENVIRONMENT SPECIFIC EXAMPLES
# ============================================================================

# DEVELOPMENT (Local)
# REACT_APP_API_URL=http://localhost:8010
# REACT_APP_ENV=development
# REACT_APP_DEBUG=true
# REACT_APP_ENABLE_DEVTOOLS=true
# REACT_APP_LOG_API_CALLS=true
# REACT_APP_HTTPS_ONLY=false

# STAGING (Beta Testing)
# REACT_APP_API_URL=https://staging-api.peripateticware.com
# REACT_APP_ENV=staging
# REACT_APP_DEBUG=false
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_ERROR_TRACKING=true
# REACT_APP_ENABLE_DEVTOOLS=false

# PRODUCTION (Live)
# REACT_APP_API_URL=https://api.peripateticware.com
# REACT_APP_ENV=production
# REACT_APP_DEBUG=false
# REACT_APP_ENABLE_DEVTOOLS=false
# REACT_APP_LOG_API_CALLS=false
# REACT_APP_HTTPS_ONLY=true
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_ERROR_TRACKING=true

# ============================================================================
# BUILD OPTIMIZATION
# ============================================================================

# Enable production source maps (for debugging in production)
GENERATE_SOURCEMAP=false

# PUBLIC_URL for serving from subdirectory (if applicable)
PUBLIC_URL=/

# ============================================================================
# IMPORTANT NOTES
# ============================================================================

# ⚠️ REACT_APP_ prefix required for Create React App to expose variables
# ⚠️ Non-REACT_APP_ variables are NOT exposed to the browser
# ⚠️ All REACT_APP_ variables are visible in browser (not secrets!)
# ⚠️ Never put API keys or secrets in REACT_APP_ variables
# ⚠️ Don't commit .env.local to version control
# ⚠️ .env.local should be in .gitignore
# ⚠️ Changes to .env.local require server restart

# ============================================================================
# TROUBLESHOOTING
# ============================================================================

# If app can't connect to API:
# 1. Check REACT_APP_API_URL is correct
# 2. Verify backend is running
# 3. Check browser console for CORS errors
# 4. Verify backend CORS settings

# If dark mode doesn't work:
# 1. Set REACT_APP_ENABLE_DARK_MODE=true
# 2. Clear browser cache
# 3. Check theme context is properly initialized

# If analytics not tracking:
# 1. Check REACT_APP_ANALYTICS_ID is set
# 2. Verify Firebase config is correct
# 3. Check browser console for errors
# 4. Verify analytics service is enabled

# If offline mode isn't working:
# 1. Check REACT_APP_ENABLE_PWA=true
# 2. Check service worker is registered
# 3. Clear browser cache and storage
# 4. Check Network tab in DevTools

# ============================================================================
# USEFUL COMMANDS
# ============================================================================

# Start development server:
# npm start

# Build for production:
# npm run build

# Run tests:
# npm test

# Analyze bundle size:
# npm run analyze

# Deploy to production:
# npm run build && npm run deploy

# ============================================================================
# DOCUMENTATION & SUPPORT
# ============================================================================

# For more information:
# - Frontend Development: docs/DEVELOPMENT.md
# - React Documentation: https://react.dev
# - Create React App: https://create-react-app.dev
# - Redux (if used): https://redux.js.org

# ==============================================================================
# frontend/.env.example
# Environment variables for Phase 6 frontend
# ==============================================================================

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=30000

# Environment
VITE_ENV=development
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_OFFLINE=true
VITE_ENABLE_ASR=true
VITE_ENABLE_PORTFOLIO_EXPORT=true

# Third-party APIs (if needed)
VITE_OPENAI_API_KEY=
VITE_MAPBOX_TOKEN=

# Analytics (optional)
VITE_ANALYTICS_ENABLED=false
VITE_GOOGLE_ANALYTICS_ID=

# Performance
VITE_CACHE_STRATEGY=service-worker
VITE_IMAGE_OPTIMIZATION=true
VITE_CODE_SPLITTING=true